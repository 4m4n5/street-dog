[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/godot_catalyst/status_panel.gd" id="1"]

[node name="StatusPanel" type="MarginContainer"]
script = ExtResource("1")
custom_minimum_size = Vector2(0, 120)
theme_override_constants/margin_left = 8
theme_override_constants/margin_right = 8
theme_override_constants/margin_top = 6
theme_override_constants/margin_bottom = 6

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 6

[node name="HeaderRow" type="HBoxContainer" parent="VBox"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="StatusLabel" type="Label" parent="VBox/HeaderRow"]
layout_mode = 2
text = "● Disconnected"

[node name="Sep1" type="VSeparator" parent="VBox/HeaderRow"]
layout_mode = 2

[node name="VersionLabel" type="Label" parent="VBox/HeaderRow"]
layout_mode = 2
text = "v?"
tooltip_text = "Plugin version"

[node name="Sep2" type="VSeparator" parent="VBox/HeaderRow"]
layout_mode = 2

[node name="PortLabel" type="Label" parent="VBox/HeaderRow"]
layout_mode = 2
text = "Port —"
tooltip_text = "WebSocket listen port"

[node name="Sep3" type="VSeparator" parent="VBox/HeaderRow"]
layout_mode = 2

[node name="ActionsLabel" type="Label" parent="VBox/HeaderRow"]
layout_mode = 2
text = "— actions"
tooltip_text = "Total actions exposed by plugin handlers"

[node name="Sep4" type="VSeparator" parent="VBox/HeaderRow"]
layout_mode = 2

[node name="CallsLabel" type="Label" parent="VBox/HeaderRow"]
layout_mode = 2
text = "0 calls"
tooltip_text = "Tool calls received since server start"

[node name="Sep5" type="VSeparator" parent="VBox/HeaderRow"]
layout_mode = 2

[node name="UptimeLabel" type="Label" parent="VBox/HeaderRow"]
layout_mode = 2
text = "—"
tooltip_text = "Time since current client connected"

[node name="Spacer" type="Control" parent="VBox/HeaderRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="CopyConfigButton" type="Button" parent="VBox/HeaderRow"]
layout_mode = 2
text = "Copy MCP Config"
tooltip_text = "Copy a Claude Code / Cursor mcpServers snippet to the clipboard"

[node name="DocsButton" type="Button" parent="VBox/HeaderRow"]
layout_mode = 2
text = "Docs"
tooltip_text = "Open portal.fireal.dev/godot-catalyst in your browser"

[node name="HSeparator" type="HSeparator" parent="VBox"]
layout_mode = 2

[node name="LogHeader" type="Label" parent="VBox"]
layout_mode = 2
text = "Recent calls"
theme_override_colors/font_color = Color(0.65, 0.65, 0.65, 1)

[node name="LogScroll" type="ScrollContainer" parent="VBox"]
layout_mode = 2
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="LogList" type="VBoxContainer" parent="VBox/LogScroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 2

[node name="EmptyHint" type="Label" parent="VBox/LogScroll/LogList"]
layout_mode = 2
text = "Waiting for tool calls…"
theme_override_colors/font_color = Color(0.5, 0.5, 0.5, 1)
